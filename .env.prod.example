APP_ENV_FILE=.env.prod

POSTGRES_DB=miniteamclaw
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-now

SESSION_SECRET=replace-with-at-least-32-characters
ADMIN_BOOTSTRAP_MODE=ui
ENABLE_LAZYCAT_FILE_PICKER=false
ATTACHMENTS_FILE_ACCESS_ROOT=/shared/uploads
ATTACHMENTS_MESSAGE_PATH_ROOT=/home/openclaw/miniteamclaw/uploads
LAZYCAT_SOURCE_FILE_ACCESS_ROOT=
OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18789
OPENCLAW_GATEWAY_AUTH_MODE=token
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
MAX_UPLOAD_BYTES=1073741824
OPENCLAW_VERBOSE_LEVEL=off
APP_URL=http://127.0.0.1:3000
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile
OIDC_BRAND_NAME=
