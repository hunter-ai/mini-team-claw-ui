APP_ENV_FILE=.env.prod

POSTGRES_DB=miniteamclaw
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-now

SESSION_SECRET=replace-with-at-least-32-characters
ADMIN_BOOTSTRAP_MODE=ui
OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_UPLOAD_DIR_CONTAINER=/shared/uploads
OPENCLAW_UPLOAD_DIR_HOST=/home/openclaw/miniteamclaw/uploads
MAX_UPLOAD_BYTES=1073741824
OPENCLAW_VERBOSE_LEVEL=off
APP_URL=http://127.0.0.1:3000
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile
